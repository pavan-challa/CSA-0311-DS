#include <stdio.h>
int main() {
    int n, i, num;
    printf("Enter the number of elements: ");
    scanf("%d", &n);
    int numbers[n];
    printf("Enter the numbers:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &numbers[i]);
    }
    printf("Results:\n");
    for (i = 0; i < n; i++) {
        if (numbers[i] % 2 == 0) {
            printf("%d is Even\n", numbers[i]);
        } else {
            printf("%d is Odd\n", numbers[i]);
        }
    }
    return 0;
}
